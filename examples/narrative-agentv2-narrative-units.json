      "type": "operational",
      "assertion": "All TypeScript code must use strict mode with explicit types - no implicit any",
      "intent": {
        "objective": "Ensure type safety and catch errors at compile time",
        "constraints": {
          "code": {
            "required_patterns": ["strict_mode", "explicit_types", "type_annotations"],
            "forbidden_patterns": ["any_type", "type_assertion_workarounds", "ts_ignore"],
            "required_libraries": ["typescript"]
          },
          "validation_rules": [
            {
              "type": "regex",
              "check": "\"strict\":\\s*true",
              "error_message": "tsconfig.json must have strict: true",
              "suggestion": "Set 'strict': true in tsconfig.json"
            }
