# Principal Narrative API - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# AI / Machine Learning
# =============================================================================

# Anthropic Claude API Key (Required for AI conflict resolution)
# Get your key from: https://console.anthropic.com/
# Estimated cost: ~$0.02-0.05 per drift resolution
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# Application Settings
# =============================================================================

# API Base URL
API_BASE_URL=http://localhost:8000

# Environment (development, staging, production)
ENVIRONMENT=development

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# Authentication & Security
# =============================================================================

# API Key for authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=your_secure_api_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Alert Integrations
# =============================================================================

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL=#drift-alerts

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=notifications@yourdomain.com

# =============================================================================
# Database & Storage
# =============================================================================

# Database path
DATABASE_PATH=data/narrative.db

# Cache TTL (seconds)
CACHE_TTL=86400

# Applied Narrative path
NARRATIVE_PATH=applied-narrative

# Central narrative repository (for multi-repo)
CENTRAL_NARRATIVE_URL=https://github.com/your-org/applied-narrative.git

# =============================================================================
# GitHub Integration
# =============================================================================

GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# Feature Flags
# =============================================================================

ENABLE_AI_RESOLUTION=true
ENABLE_SEMANTIC_DRIFT=true
ENABLE_PDF_EXPORT=false
ENABLE_MULTI_REPO=true
ENABLE_ALERTS=true
