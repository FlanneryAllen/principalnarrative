# Principal Narrative - Environment Configuration

# Required: Anthropic Claude API Key for LLM services
ANTHROPIC_API_KEY=

# Optional: Slack Integration (for ingestion from Slack channels)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Optional: GitHub Integration (for webhook and ingestion)
GITHUB_TOKEN=

# Optional: JWT Authentication Settings (defaults provided)
# PN_JWT_SECRET=principal-narrative-dev-secret-change-in-production
# PN_TOKEN_EXPIRE_MINUTES=60
# PN_REFRESH_TOKEN_DAYS=7

# Optional: Vector Store Configuration
# CHROMA_PERSIST_DIRECTORY=./chroma_db
