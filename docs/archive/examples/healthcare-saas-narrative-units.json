          "content": {
            "required_themes": ["security", "compliance", "trust", "patient_privacy"],
            "forbidden_themes": ["move_fast_break_things", "disruption", "cheap", "discount"],
            "tone": "professional",
            "target_audience": "healthcare_decision_makers"
