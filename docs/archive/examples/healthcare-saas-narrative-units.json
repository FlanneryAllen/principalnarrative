        "tags": ["product", "api", "performance"]
      }
    },
    {
      "id": "operational_authentication_oauth",
      "type": "operational",
      "assertion": "All API authentication must use OAuth 2.0 with refresh tokens and support for MFA",
      "intent": {
        "objective": "Implement secure, industry-standard authentication",
        "constraints": {
          "code": {
            "required_patterns": ["oauth2", "refresh_token", "mfa_support", "jwt_signing"],
            "forbidden_patterns": ["basic_auth", "api_keys_in_url", "password_storage_plaintext"],
            "required_libraries": ["passport", "jsonwebtoken", "@types/passport"]
          },
          "validation_rules": [
            {
              "type": "ast_pattern",
              "check": "jwt\\.sign.*expiresIn",
              "error_message": "JWT tokens must have expiration times",
              "suggestion": "Add expiresIn option to jwt.sign()"
            },
            {
              "type": "regex",
              "check": "audit.*auth",
              "error_message": "Authentication events must be audited",
              "suggestion": "Add audit() call after authentication"
            }
          ]
        },
        "evidence_required": ["auth_test_coverage_95_percent", "oauth_flow_documented"]
      },
      "dependencies": ["core_story_healthcare_trust"],
      "validationState": "ALIGNED",
      "confidence": 1.0,
      "metadata": {
        "created_at": "2026-02-10T00:00:00Z",
        "created_by": "security_lead",
        "tags": ["operational", "authentication", "security"]
      }
    },
    {
      "id": "operational_data_encryption",
      "type": "operational",
      "assertion": "All patient data must be encrypted at rest using AES-256 and in transit using TLS 1.3",
      "intent": {
        "objective": "Ensure patient data is always encrypted",
        "constraints": {
          "code": {
            "required_patterns": ["aes_256", "tls_1_3", "kms", "key_rotation"],
            "forbidden_patterns": ["plaintext_storage", "md5", "sha1", "tls_1_0", "tls_1_1"],
            "required_libraries": ["@aws-sdk/client-kms", "crypto"]
          },
          "validation_rules": [
            {
              "type": "regex",
              "check": "encrypt.*aes.*256",
              "error_message": "Encryption must use AES-256",
              "suggestion": "Use crypto.createCipheriv('aes-256-gcm', ...)"
            }
          ]
        },
        "evidence_required": ["encryption_audit_passed", "key_rotation_automated"]
      },
      "dependencies": ["core_story_healthcare_trust"],
      "validationState": "ALIGNED",
      "confidence": 1.0,
      "metadata": {
        "created_at": "2026-02-10T00:00:00Z",
        "created_by": "security_lead",
        "tags": ["operational", "encryption", "security"]
      }
    },
    {
      "id": "operational_audit_logging",
      "type": "operational",
      "assertion": "All access to patient data must be logged with timestamp, user ID, action, and data accessed",
      "intent": {
        "objective": "Maintain complete audit trail for compliance",
        "constraints": {
          "code": {
            "required_patterns": ["audit_log", "structured_logging", "log_correlation_id"],
            "forbidden_patterns": ["console.log", "printf", "print"],
            "required_libraries": ["winston", "pino"]
          },
          "validation_rules": [
            {
              "type": "ast_pattern",
              "check": "audit.*userId.*action.*timestamp",
              "error_message": "Audit logs must include userId, action, and timestamp",
              "suggestion": "Use audit({ userId, action, timestamp, resource })"
            }
          ]
        },
        "evidence_required": ["audit_logs_retained_7_years", "log_analysis_implemented"]
      },
      "dependencies": ["core_story_healthcare_trust"],
      "validationState": "ALIGNED",
      "confidence": 1.0,
      "metadata": {
        "created_at": "2026-02-10T00:00:00Z",
        "created_by": "compliance_officer",
        "tags": ["operational", "audit", "compliance"]
      }
    },
    {
      "id": "operational_api_versioning",
      "type": "operational",
      "assertion": "All API endpoints must use semantic versioning and maintain backward compatibility for at least 12 months",
      "intent": {
        "objective": "Ensure developers can rely on stable APIs",
        "constraints": {
          "code": {
            "required_patterns": ["api_version_header", "deprecation_warnings", "version_prefix"],
            "forbidden_patterns": ["breaking_changes_in_patch", "removing_fields_without_deprecation"]
          },
          "validation_rules": [
            {
              "type": "regex",
              "check": "/api/v[0-9]+/",
              "error_message": "API routes must include version prefix",
              "suggestion": "Use /api/v1/resource format"
            }
          ]
        },
        "evidence_required": ["api_changelog_maintained", "deprecated_endpoints_documented"]
      },
      "dependencies": ["core_story_developer_experience"],
      "validationState": "ALIGNED",
      "confidence": 0.95,
      "metadata": {
        "created_at": "2026-02-15T00:00:00Z",
        "created_by": "api_architect",
        "tags": ["operational", "api", "versioning"]
      }
    },
    {
      "id": "operational_error_handling",
      "type": "operational",
      "assertion": "All API errors must return standard HTTP codes with detailed error messages and request IDs for support",
      "intent": {
        "objective": "Make debugging easy for developers",
        "constraints": {
          "code": {
            "required_patterns": ["request_id", "error_code", "error_message", "http_status"],
            "forbidden_patterns": ["generic_500_error", "stack_traces_in_production"]
          },
          "validation_rules": [
            {
              "type": "ast_pattern",
              "check": "res.*status.*json.*requestId",
              "error_message": "Error responses must include requestId",
              "suggestion": "Add requestId to error response body"
            }
          ]
        },
        "evidence_required": ["error_documentation_complete", "support_can_track_errors"]
      },
      "dependencies": ["core_story_developer_experience"],
      "validationState": "ALIGNED",
      "confidence": 0.9,
      "metadata": {
        "created_at": "2026-02-15T00:00:00Z",
        "created_by": "api_architect",
        "tags": ["operational", "error_handling", "developer_experience"]
      }
    },
    {
      "id": "operational_rate_limiting",
      "type": "operational",
      "assertion": "All API endpoints must implement rate limiting with clear headers and upgrade paths for higher limits",
      "intent": {
        "objective": "Prevent abuse while enabling growth",
        "constraints": {
          "code": {
            "required_patterns": ["rate_limit_headers", "429_status_code", "retry_after_header"],
            "forbidden_patterns": ["unlimited_requests", "silent_rate_limiting"]
          },
          "validation_rules": [
            {
              "type": "regex",
              "check": "X-RateLimit-(Limit|Remaining|Reset)",
              "error_message": "Rate limit headers must be present",
              "suggestion": "Add X-RateLimit-* headers to response"
            }
          ]
        },
        "evidence_required": ["rate_limits_documented", "upgrade_path_exists"]
      },
      "dependencies": ["core_story_developer_experience"],
      "validationState": "ALIGNED",
      "confidence": 0.95,
      "metadata": {
        "created_at": "2026-02-15T00:00:00Z",
        "created_by": "infrastructure_lead",
        "tags": ["operational", "rate_limiting", "scalability"]
      }
    },
