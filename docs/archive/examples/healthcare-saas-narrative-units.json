    {
      "id": "product_narrative_patient_data_api",
      "type": "product_narrative",
      "assertion": "Our Patient Data API provides real-time access to EHR data with sub-100ms latency and 99.99% uptime",
      "intent": {
        "objective": "Enable developers to build fast, reliable patient-facing applications",
        "constraints": {
          "code": {
            "required_patterns": ["caching", "circuit_breaker", "retry_logic"],
            "forbidden_patterns": ["synchronous_blocking_calls"]
          }
        },
        "evidence_required": ["p95_latency_under_100ms", "uptime_99_99_percent"]
      },
      "dependencies": ["core_story_developer_experience", "core_story_healthcare_trust"],
