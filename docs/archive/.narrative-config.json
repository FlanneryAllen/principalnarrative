{
  "$schema": "https://principalnarrative.dev/schemas/narrative-config.json",
  "version": "1.0.0",
  "repository": {
    "name": "narrative-agentv2",
    "type": "service",
    "description": "Principal Narrative API service - drift detection and coherence management",
    "owner": {
      "team": "platform",
      "contact": "platform@example.com"
    }
  },
  "narrative": {
    "mode": "central",
    "central_repository": {
      "url": "https://github.com/YourOrg/applied-narrative.git",
      "branch": "main",
      "path": ".principalnarrative/applied-narrative",
      "sync_interval": "daily",
      "auto_pull": true
    },
    "local_narrative": {
      "enabled": true,
      "path": ".principalnarrative/applied-narrative",
      "extends_central": true,
      "allow_overrides": true
    },
    "override_policy": "local_wins"
  },
  "drift_detection": {
    "enabled": true,
    "check_against_central": true,
    "local_only": false,
    "scan_schedule": "0 9 * * *",
    "auto_report_to_org": true,
    "severity_threshold": "medium"
  },
  "integrations": {
    "central_api": {
      "enabled": true,
      "url": "https://narrative-api.example.com",
      "api_key_env": "NARRATIVE_API_KEY",
      "report_drift": true,
      "report_analytics": true
    },
    "slack": {
      "enabled": false,
      "webhook_url_env": "SLACK_WEBHOOK_URL",
      "notify_on_drift": true,
      "channels": {
        "drift_alerts": "#narrative-drift",
        "resolutions": "#narrative-fixes"
      }
    }
  },
  "analytics": {
    "track_local": true,
    "report_to_central": true,
    "retention_days": 90,
    "aggregate_with_org": true
  },
  "tags": [
    "backend",
    "api",
    "python",
    "fastapi"
  ],
  "metadata": {
    "created_at": "2025-12-15T00:00:00Z",
    "last_updated": "2025-12-15T00:00:00Z",
    "config_version": "1.0.0"
  }
}
